# Banco MongoDB. Use credenciais exclusivas e TLS em produção.
DATABASE_URL="mongodb://127.0.0.1:27017/biblion"

# URL pública incorporada no build. Produção deve usar HTTPS e não ter caminho.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ALLOWED_ORIGINS=""
# Desenvolvimento local: false. Produção: true somente atrás de proxy confiável
# que bloqueie acesso direto e saneie x-forwarded-for/host/proto.
TRUST_PROXY="false"

# Selecione explicitamente um provedor. Preencha somente chaves no ambiente real.
AI_PROVIDER="gemini"
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Recomendado em produção com mais de uma instância.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Opcional para o app Android; quando definido, deve ser uma origem HTTPS.
CAPACITOR_SERVER_URL=""

# Variáveis temporárias, usadas apenas pelo script de migração inicial.
OWNER_USERNAME=""
OWNER_PASSWORD=""
DRY_RUN="true"
APPLY_MIGRATION="false"
RESET_OWNER_PASSWORD="false"
