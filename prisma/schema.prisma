generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  username           String
  usernameNormalized String        @unique
  passwordHash       String
  authVersion        Int           @default(0)
  role               UserRole      @default(MEMBER)
  displayName        String?
  bio                String?
  avatarUrl          String?
  accentColor        String        @default("violet")
  locale             String        @default("pt-BR")
  isActive           Boolean       @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  sessions           UserSession[]
  sermoes            Sermao[]
  esbocos            Esboco[]
  anotacoes          Anotacao[]
  favoritos          Favorito[]
  revistas           RevistaEBD[]
  licoes             LicaoEBD[]
  configuracoes      Configuracao[]

  @@index([role, isActive])
}

model UserSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash   String   @unique
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authVersion Int      @default(0)
  userAgent   String?
  expiresAt   DateTime
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Sermao {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String   @db.ObjectId
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  titulo      String
  tema        String?
  textoBase   String
  introducao  String?
  topicos     String?
  conclusao   String?
  aplicacao   String?
  categoria   String?
  tags        String?
  publicado   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId, updatedAt])
}

model Esboco {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  titulo    String
  textoBase String?
  conteudo  String
  modelo    String?
  categoria String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt])
}

model Anotacao {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId    String   @db.ObjectId
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  titulo     String?
  conteudo   String
  livro      String?
  capitulo   Int?
  versiculo  Int?
  referencia String?
  tipo       String   @default("geral")
  tags       String[] @default([])
  fixada     Boolean  @default(false)
  cor        String   @default("default")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId, updatedAt])
  @@index([ownerId, livro, capitulo, versiculo])
}

model Favorito {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId    String   @db.ObjectId
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  tipo       String
  referencia String
  titulo     String?
  createdAt  DateTime @default(now())

  @@index([ownerId, createdAt])
}

model RevistaEBD {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  ownerId   String     @db.ObjectId
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  titulo    String
  trimestre String?
  ano       String?
  tema      String?
  capa      String?
  licoes    LicaoEBD[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([ownerId, createdAt])
}

model LicaoEBD {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String      @db.ObjectId
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  numero      Int?
  titulo      String
  data        DateTime?
  revistaId   String?     @db.ObjectId
  revista     RevistaEBD? @relation(fields: [revistaId], references: [id], onDelete: Cascade)
  textoBase   String?
  objetivos   String?
  introducao  String?
  topicos     String?
  conclusao   String?
  perguntas   String?
  resumo      String?
  aplicacao   String?
  esboco      String?
  conteudoRaw String?
  arquivo     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([ownerId, createdAt])
  @@index([ownerId, revistaId])
}

model Configuracao {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: NoAction)
  chave     String
  valor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, chave])
  @@index([ownerId, updatedAt])
}
